# Configuração da API OpenAI
# Copie este arquivo para .env e adicione sua chave de API

# Sua chave de API OpenAI
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-seu-api-key-aqui

# Timeout padrão para scraping (em ms)
SCRAPING_TIMEOUT=10000

# Modelo OpenAI a usar
# Opções: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo
OPENAI_MODEL=gpt-4
